import os
import cv2
import numpy as np
import matplotlib.pyplot as plt
import tensorflow as tf


# 1. Load the MNIST dataset from Keras
mnist = tf.keras.datasets.mnist
(x_train, y_train), (x_test, y_test) = mnist.load_data()

# 2. Normalize the pixel data (scaling 0-255 to 0-1)
x_train = tf.keras.utils.normalize(x_train, axis=1)
x_test = tf.keras.utils.normalize(x_test, axis=1)

# 3. Define the Neural Network Architecture
model = tf.keras.models.Sequential()
model.add(tf.keras.layers.Flatten(input_shape=(28, 28))) # Input layer
model.add(tf.keras.layers.Dense(128, activation='relu')) # Hidden layer 1
model.add(tf.keras.layers.Dense(128, activation='relu')) # Hidden layer 2
model.add(tf.keras.layers.Dense(10, activation='softmax')) # Output layer (10 digits)

# 4. Compile the model
model.compile(optimizer='adam', 
              loss='sparse_categorical_crossentropy', 
              metrics=['accuracy'])

# 5. Train the model
model.fit(x_train, y_train, epochs=3)

# 6. Save the model (Note: modern Keras uses .keras extension)
model.save('handwritten.keras')

# 7. Evaluate the model performance
loss, accuracy = model.evaluate(x_test, y_test)
print(f"Loss: {loss}")
print(f"Accuracy: {accuracy}")
#Loss: 0.09991395473480225
#Accuracy: 0.9675999879837036


# 8. Predict custom images (from a 'digits' folder)
image_number = 1
while os.path.isfile(f"digits/digit{image_number}.png"):
    try:
        # Load and process custom image
        img = cv2.imread(f"digits/digit{image_number}.png")[:,:,0] 
        img = np.invert(np.array([img])) # Invert colors to match MNIST
        
        # Make prediction
        prediction = model.predict(img)
        print(f"This digit is probably a {np.argmax(prediction)}")
        
        # Display image
        plt.imshow(img[0], cmap=plt.cm.binary)
        plt.show()
    except Exception as e:
        print(f"Error: {e}")
    finally:
        image_number += 1
